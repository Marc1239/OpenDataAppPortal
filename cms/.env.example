# MongoDB connection
DATABASE_URI=mongodb://localhost:27017/opendata

# Payload secret (generate with `openssl rand -hex 32`)
PAYLOAD_SECRET=replace-with-random-secret

# Payload public URL (used for admin UI, CORS, email links)
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# Frontend URL for revalidation webhook
FRONTEND_URL=http://localhost:3000
REVALIDATE_SECRET=replace-me

# Seed admin user (only used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123
