# Payload CMS
PAYLOAD_SECRET=replace-with-long-random-string
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# Frontend
NEXT_PUBLIC_PAYLOAD_URL=http://localhost:3001
PAYLOAD_REVALIDATE=60

# Shared
FRONTEND_URL=http://localhost:3000
REVALIDATE_SECRET=replace-with-random-string

# Seed admin (only used on first run)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123

# Production (docker-compose.prod.yml)
FRONTEND_DOMAIN=portal.example.com
CMS_DOMAIN=cms.example.com
